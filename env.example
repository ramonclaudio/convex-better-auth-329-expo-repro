# Copy to .env.local. `npx convex dev` writes EXPO_PUBLIC_CONVEX_URL and
# EXPO_PUBLIC_CONVEX_SITE_URL for you. Set BETTER_AUTH_SECRET on the Convex
# deployment via `npx convex env set`.

# EXPO_PUBLIC_CONVEX_URL=https://your-project-name.convex.cloud
# EXPO_PUBLIC_CONVEX_SITE_URL=https://your-project-name.convex.site
